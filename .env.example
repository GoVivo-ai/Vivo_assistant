# Server
PORT=3000
# Runtime connection. With Supabase use the transaction pooler (port 6543):
# postgresql://postgres.<ref>:<password>@aws-X-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=vivo_assistant
DATABASE_URL=postgresql://vivo:vivo@localhost:5432/vivo_assistant?schema=public
# Non-pooled connection for prisma migrate. With Supabase use the session pooler (port 5432).
# For local Postgres, just repeat DATABASE_URL.
DIRECT_URL=postgresql://vivo:vivo@localhost:5432/vivo_assistant?schema=public

# Slack (create app at https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
# Optional: set this to run in Socket Mode (recommended for local dev, no public URL needed for Slack)
SLACK_APP_TOKEN=xapp-...

# Public base URL of this server (used for OAuth callbacks; use ngrok URL locally)
APP_BASE_URL=https://your-domain-or-ngrok-url

# AI provider: openai | anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model override (defaults: gpt-4o-mini / claude-haiku-4-5-20251001)
AI_MODEL=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain-or-ngrok-url/oauth/google/callback

# ClickUp OAuth (https://app.clickup.com/settings/team/clickup-api)
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_REDIRECT_URI=https://your-domain-or-ngrok-url/oauth/clickup/callback

# 32+ char secret used for AES-256-GCM token encryption and OAuth state signing.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Password for the /admin activity dashboard (Basic Auth, username "admin").
# Leave empty to disable the dashboard. Generate with: openssl rand -hex 16
ADMIN_DASHBOARD_KEY=

COMPANY_TIMEZONE=America/Bogota
