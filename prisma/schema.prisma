generator client {
  provider      = "prisma-client-js"
  // "rhel-openssl-3.0.x" is the runtime used by Vercel serverless functions.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations — required with Supabase,
  // whose transaction pooler (port 6543) can't run DDL. Use the session
  // pooler (port 5432) or the direct db host here.
  directUrl = env("DIRECT_URL")
}

enum Provider {
  google
  clickup
}

model User {
  id          String       @id @default(cuid())
  slackUserId String
  slackTeamId String
  name        String?
  email       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  connections  Connection[]
  auditLogs    AuditLog[]
  chatMessages ChatMessage[]
  tickets      Ticket[]

  @@unique([slackUserId, slackTeamId])
}

model Ticket {
  id             String    @id @default(cuid())
  // Human-friendly sequential number shown to users ("Ticket #12").
  number         Int       @unique @default(autoincrement())
  userId         String
  title          String
  description    String
  category       String // access | bug | data | performance | integration | feature_request | other
  priority       String // low | medium | high | urgent
  status         String    @default("open") // open | in_progress | resolved | closed
  lang           String    @default("es") // language the user opened the ticket in
  adminNote      String? // internal notes, never sent to the user
  resolutionNote String? // sent to the user when resolved
  // Pending "we need more info" request: when the DM was sent and what was
  // asked. Cleared once the user's reply is attached to the ticket.
  infoRequestedAt DateTime?
  infoQuestion    String?
  resolvedAt     DateTime?
  notifiedAt     DateTime? // when the Slack DM about the resolution was delivered
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments    TicketAttachment[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model TicketAttachment {
  id          String   @id @default(cuid())
  ticketId    String
  slackFileId String
  name        String
  mimetype    String
  // Slack url_private — needs the bot token to download, served to the
  // admin via the authenticated /admin/files/:id proxy.
  urlPrivate  String
  size        Int      @default(0)
  createdAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  source    String   @default("dm") // dm | mention
  userText  String
  botReply  String
  intent    String?
  // JSON array of Slack image files sent with the message, so the admin chat
  // view can render the screenshots via /admin/chat-files/:id/:idx.
  filesJson String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Connection {
  id                    String    @id @default(cuid())
  userId                String
  provider              Provider
  providerAccountId     String?
  providerEmail         String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  scopes                String?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  provider  String?
  query     String?
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
