generator client {
  provider      = "prisma-client-js"
  // "rhel-openssl-3.0.x" is the runtime used by Vercel serverless functions.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations — required with Supabase,
  // whose transaction pooler (port 6543) can't run DDL. Use the session
  // pooler (port 5432) or the direct db host here.
  directUrl = env("DIRECT_URL")
}

enum Provider {
  google
  clickup
}

model User {
  id          String       @id @default(cuid())
  slackUserId String
  slackTeamId String
  name        String?
  email       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  connections Connection[]
  auditLogs   AuditLog[]

  @@unique([slackUserId, slackTeamId])
}

model Connection {
  id                    String    @id @default(cuid())
  userId                String
  provider              Provider
  providerAccountId     String?
  providerEmail         String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  scopes                String?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  provider  String?
  query     String?
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
